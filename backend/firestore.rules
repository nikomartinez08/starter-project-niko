rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Function to check if the incoming data is a valid Article
    function isValidArticle(data) {
      return data.keys().hasAll(['author', 'title', 'description', 'urlToImage', 'publishedAt', 'content']) &&
             data.author is string && data.author.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.description is string && data.description.size() > 0 &&
             data.urlToImage is string && data.urlToImage.size() > 0 &&
             data.publishedAt is string &&
             data.content is string && data.content.size() > 0 &&
             (!data.keys().hasAny(['url']) || data.url is string);
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isValidArticle(request.resource.data);
      allow update: if isValidArticle(request.resource.data);
      allow delete: if false; // Keep delete restricted
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }
  }
}